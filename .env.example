# .env — set these as HuggingFace Space "Secrets" (keys) and "Variables" (rest).
# For local testing: cp .env.example .env

# ---- AI provider ----------------------------------------------------------
# deepseek (default, validated) | openai | gemini | anthropic
AI_PROVIDER=deepseek
# Set the key matching AI_PROVIDER (only one is needed). SECRET.
DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# ---- Telegram -------------------------------------------------------------
# Bot token from @BotFather. SECRET.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to DM the bot (DM @userinfobot
# to get yours). Leave empty to fall back to pairing mode.
TELEGRAM_ALLOWED_USER_IDS=

# ---- Gateway / Control UI -------------------------------------------------
# Required to bind beyond loopback. If empty, an ephemeral one is generated each
# boot (Telegram still works; only the Control-UI login token rotates). SECRET.
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
# HF must see this port. Keep 7860 unless you know what you're doing.
PORT=7860

# ---- Cloudflare R2 persistence (optional but recommended) -----------------
# Without these, all state is lost when the Space restarts/sleeps.
# S3-compatible R2 credentials. SECRETS.
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=openclaw-state
S3_PREFIX=openclaw
S3_REGION=auto
# Seconds between background syncs to R2.
R2_SYNC_INTERVAL=300

# ---- Misc -----------------------------------------------------------------
OPENCLAW_TZ=UTC
