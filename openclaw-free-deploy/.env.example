# ==============================================================================
# .env.example â€” copy to .env (local) or paste into HF Space "Secrets".
#
# On HuggingFace: set these as SECRETS (encrypted), NOT Variables. Variables are
# world-readable on public Spaces.
# ==============================================================================

# ---------- Channels (#8) ----------------------------------------------------
# Comma-separated. Telegram is fully featured; discord/slack need their tokens.
CHANNELS=telegram

# ---------- Telegram (required if telegram in CHANNELS) ----------------------
# From @BotFather â†’ /newbot. Looks like 123456789:ABC-DEF...
TELEGRAM_BOT_TOKEN=

# STRONGLY recommended: lock the bot to your numeric user ID(s) (from @userinfobot).
# Without this, the first DM gets a pairing code instead of a reply.
# Comma-separated for multiple: "111111111,222222222"
TELEGRAM_ALLOWED_USER_IDS=

# Mode: polling (default, simplest) or webhook (advanced; needs PUBLIC_BASE_URL).
# Webhook mode lets the Space sleep and wakes it on incoming messages.
TELEGRAM_MODE=polling

# --- Webhook mode only (ignore for polling) ---
# The public HTTPS URL Telegram will call (your Worker domain or the HF URL).
PUBLIC_BASE_URL=
# Leave blank to auto-generate; the value is written to ~/.openclaw/.webhook-secret.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/telegram-webhook
# Internal gateway port used in webhook mode (Control UI + health live here).
GATEWAY_INTERNAL_PORT=18789

# ---------- Discord (only if discord in CHANNELS) ----------------------------
DISCORD_BOT_TOKEN=

# ---------- Slack (only if slack in CHANNELS) --------------------------------
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ---------- AI provider (pick ONE) -------------------------------------------
# claude | openai | gemini | deepseek
AI_PROVIDER=claude

# Optional model override. Defaults per provider:
#   claudeâ†’anthropic/claude-sonnet-4-5  openaiâ†’openai/gpt-5
#   geminiâ†’google/gemini-2.5-pro        deepseekâ†’deepseek/deepseek-chat
MODEL=

# Supply ONLY the key matching AI_PROVIDER.
# Note: Anthropic promo credits don't work with the API â€” needs paid credits.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---------- Cloudflare R2 (optional â€” needed for persistence) ----------------
# Without these, state is wiped on every restart.
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=openclaw-data
S3_REGION=auto
S3_PREFIX=openclaw-state
# Periodic push interval (seconds). 0 disables; state still syncs on shutdown
# and on SIGUSR1.
R2_SYNC_INTERVAL=300

# ---------- Observability (#9, optional) -------------------------------------
# Point at a free OTLP/HTTP collector (Grafana Cloud, Honeycomb, Axiomâ€¦).
# Requires the @openclaw/diagnostics-otel plugin (see README).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=openclaw-gateway

# ---------- Port (rarely changed) --------------------------------------------
# HF Spaces requires 7860. Only change if NOT deploying to HF.
PORT=7860
